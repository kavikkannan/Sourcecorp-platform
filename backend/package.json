{
  "name": "sourcecorp-backend",
  "version": "1.0.0",
  "description": "SourceCorp Platform Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc || true && cp -r src/assets dist/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:hierarchy": "ts-node src/db/migrate-hierarchy.ts",
    "migrate:source-type": "ts-node src/db/migrate-add-source-type.ts",
    "migrate:notifications": "ts-node src/db/migrate-add-case-notifications.ts",
    "migrate:finance-templates": "ts-node src/db/migrate-finance-templates.ts",
    "migrate:phase4": "ts-node src/db/migrate-phase4-tasks-notes.ts",
    "migrate:phase4-permissions": "ts-node src/db/migrate-phase4-permissions.ts",
    "migrate:phase4-all": "ts-node src/db/migrate-phase4-all.ts",
    "migrate:initial-obligation-template": "ts-node src/db/migrate-initial-obligation-template.ts",
    "migrate:fix-obligation-items": "ts-node src/db/migrate-fix-obligation-items.ts",
    "migrate:initial-cam-template": "ts-node src/db/migrate-initial-cam-template.ts",
    "migrate:announcements-enhancements": "ts-node src/db/migrate-announcements-enhancements.ts",
    "migrate:user-delete-permission": "ts-node src/db/migrate-user-delete-permission.ts",
    "migrate:note-schedule-attachments": "ts-node src/db/migrate-add-note-schedule-attachments.ts",
    "migrate:customer-detail-sheets": "ts-node src/db/migrate-customer-detail-sheets.ts",
    "migrate:add-sales-report-category": "ts-node src/db/migrate-add-sales-report-category.ts",
    "migrate:add-assign-permission-to-admin": "ts-node src/db/migrate-add-assign-permission-to-admin.ts",
    "migrate:add-delete-permission-to-admin": "ts-node src/db/migrate-add-delete-permission-to-admin.ts",
    "migrate:update-case-number-format": "ts-node src/db/migrate-update-case-number-format.ts",
    "migrate:customer-detail-permissions": "ts-node src/db/migrate-customer-detail-permissions.ts",
    "migrate:customer-detail-change-requests": "ts-node src/db/migrate-customer-detail-change-requests.ts",
    "migrate:link-change-requests-to-notifications": "ts-node src/db/migrate-link-change-requests-to-notifications.ts",
    "migrate:error-logs": "ts-node src/db/migrate-add-error-logs-table.ts"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/pdfkit": "^0.13.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "axios": "1.14.0"
  }
}
